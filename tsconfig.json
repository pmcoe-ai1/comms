{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "declaration": true,
    "noEmit": true,
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@generated/*": [
        "generated/*"
      ],
      "@rules/*": [
        "src/rules/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "generated/**/*",
    "generated-subscription/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
