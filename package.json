{
  "name": "dkce-prototype",
  "version": "1.0.0",
  "private": true,
  "description": "Domain Knowledge Crystallisation Engine prototype",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:scenarios": "jest tests/scenarios",
