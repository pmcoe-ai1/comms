    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@types/jest": "^30.0.0",
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  }
}
